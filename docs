### Servo Mode Control Functions

```c
// Set duty cycle
void comm_can_set_duty(uint8_t controller_id, float duty) {
    int32_t idx = 0;
    uint8_t buffer[4];
    buffer_append_int32(buffer, (int32_t)(duty * 100000.0), &idx);
    comm_can_transmit_eid(controller_id | ((uint32_t)0 << 8), buffer, idx);
}

// Set current (torque)
void comm_can_set_current(uint8_t controller_id, float current) {
    int32_t idx = 0;
    uint8_t buffer[4];
    buffer_append_int32(buffer, (int32_t)(current * 1000.0), &idx);
    comm_can_transmit_eid(controller_id | ((uint32_t)1 << 8), buffer, idx);
}

// Set velocity
void comm_can_set_rpm(uint8_t controller_id, float rpm) {
    int32_t idx = 0;
    uint8_t buffer[4];
    buffer_append_int32(buffer, (int32_t)rpm, &idx);
    comm_can_transmit_eid(controller_id | ((uint32_t)3 << 8), buffer, idx);
}

// Set position
void comm_can_set_pos(uint8_t controller_id, float pos) {
    int32_t idx = 0;
    uint8_t buffer[4];
    buffer_append_int32(buffer, (int32_t)(pos * 10000.0), &idx);
    comm_can_transmit_eid(controller_id | ((uint32_t)4 << 8), buffer, idx);
}

// Set origin
void comm_can_set_origin(uint8_t controller_id, uint8_t permanent) {
    uint8_t buffer[1] = {permanent};
    comm_can_transmit_eid(controller_id | ((uint32_t)5 << 8), buffer, 1);
}

// Disable motor
void comm_can_disable(uint8_t controller_id) {
    uint8_t buffer[8] = {0};
    comm_can_transmit_eid(controller_id | ((uint32_t)15 << 8), buffer, 0);
}
```

